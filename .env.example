# ── Misión Riesgo Cero — Variables de Entorno ─────────────────────────────
# Copia este archivo como .env.local y completa los valores reales.
# NUNCA subas .env.local al repositorio (ya está en .gitignore).

# ── Azure AD / Microsoft Entra ID ─────────────────────────────────────────
# Obtenidos desde Azure Portal → App Registrations → tu app → Overview

# Application (client) ID
VITE_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Directory (tenant) ID
VITE_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── SharePoint ────────────────────────────────────────────────────────────
# ID del sitio de SharePoint donde están las listas.
# Cómo obtenerlo:
#   GET https://graph.microsoft.com/v1.0/sites/{hostname}:/{server-relative-path}
#   Ej: GET https://graph.microsoft.com/v1.0/sites/agrosuper.sharepoint.com:/sites/MRC
#   El campo "id" de la respuesta es el que va aquí.
VITE_SHAREPOINT_SITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL del sitio SharePoint (usado en todos los servicios Graph API)
VITE_SHAREPOINT_SITE_URL=https://agrosuper.sharepoint.com/sites/SSOASCOMERCIAL

# ── GUIDs de listas SharePoint ────────────────────────────────────────────
# Cómo obtener el GUID de una lista:
#   En SharePoint → Configuración de la lista → la URL contiene ?List={GUID}
#   O desde _layouts/15/listedit.aspx?List={GUID}

# Lista "Administradores MRC" — creada manualmente en SharePoint
# La app no tiene permiso para crearla automáticamente; configurar este GUID
VITE_SP_ADMINS_LIST_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Notas de configuración ────────────────────────────────────────────────
# Sin estas variables la app corre en "dev mode":
#   - Login simulado (usuario demo@agrosuper.cl con rol admin)
#   - SharePoint: no se hacen llamadas reales, los envíos se guardan en memoria
#   - People Picker: busca en lista mock local (sin llamadas a Graph API)
